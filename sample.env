# Copy this file to `.env` and adjust the values for your setup.

# --- Paths ------------------------------------------------------------------
# Directory holding the movie files (the gen/sampling commands append the
# "<movie-name>.<movie-format>" to this path).
movie_path="./assets/movies/"
# Target image rendered as a mosaic. Override per-run with `gen --target-img`.
image_path="./assets/target.jpg"
# Where sampled frames are cached (a per-movie subfolder is created inside).
movie_frames_path="./assets/movies-sampler"

# --- Sampling / matching ----------------------------------------------------
# Size of the frame pool drawn from the movie; also the suffix of the rgb
# cache file (assets/<movie>-<frame_count_per_box>.csv). If you add/remove
# frames by hand, delete that csv so the cache is rebuilt.
frame_count_per_box=10000000
# Pixel height of each frame cell in the final poster.
final_box_height=400
# Number of frame cells stacked vertically per column — higher = finer mosaic.
box=100
# Upscale factor applied to the target before blurring (more detail, slower).
upsample=8

# --- Frame aspect ratio (width / height) ------------------------------------
# NOTE: `gen` overrides this with the target image's actual ratio, so it only
# matters for commands that don't recompute it. Common source ratios:
# ratio=1.777777777   # 1920x1080
# ratio=1.333333333   # 1440x1080
# ratio=1.846153846   # 1920x1040

# --- Color blending: output = frame*alpha + target_mean_color*beta ----------
# Used by `gen --colored`. The raw-frame mode (default, no --colored) forces
# alpha=1, beta=0 regardless of these values.
#   alpha=1   beta=0    -> raw, untinted movie frames
#   alpha=0.7 beta=0.7  -> frames tinted toward the target colors
alpha=0.7
beta=0.7

# --- Optional center-crop of sampled frames ---------------------------------
# Crop each frame to this width/height before use (e.g. to strip letterboxing
# or match an aspect). Leave unset (or 0) to keep frames as-is.
# crop_box_x=1440
# crop_box_y=1080
